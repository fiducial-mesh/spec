{
  "$defs": {
    "Effect": {
      "enum": [
        "pure",
        "mutate_local",
        "mutate_external"
      ],
      "title": "Effect",
      "type": "string"
    },
    "LifecycleState": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "title": "LifecycleState",
      "type": "string"
    },
    "TrustTier": {
      "enum": [
        "experimental",
        "community",
        "blessed",
        "core"
      ],
      "title": "TrustTier",
      "type": "string"
    }
  },
  "description": "PCS Skill Spec v0.1 \u2014 substrate-agnostic plugin declaration.",
  "properties": {
    "name": {
      "pattern": "^[a-z][a-z0-9_-]*$",
      "title": "Name",
      "type": "string"
    },
    "version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Version",
      "type": "string"
    },
    "owner": {
      "minLength": 1,
      "title": "Owner",
      "type": "string"
    },
    "lifecycle_state": {
      "$ref": "#/$defs/LifecycleState"
    },
    "trust_tier": {
      "$ref": "#/$defs/TrustTier"
    },
    "effect": {
      "$ref": "#/$defs/Effect"
    },
    "is_idempotent": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Is Idempotent"
    },
    "requires_capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Requires Capabilities",
      "type": "array"
    },
    "inputs": {
      "additionalProperties": true,
      "title": "Inputs",
      "type": "object"
    },
    "outputs": {
      "additionalProperties": true,
      "title": "Outputs",
      "type": "object"
    },
    "acknowledged_external_risk": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Acknowledged External Risk"
    }
  },
  "required": [
    "name",
    "version",
    "owner",
    "lifecycle_state",
    "trust_tier",
    "effect"
  ],
  "title": "SkillSpec",
  "type": "object"
}
